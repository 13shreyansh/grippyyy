# ══════════════════════════════════════════════════════════════════
# Grippy V5.5 Environment Variables
# Copy this file to .env and fill in the values.
# ══════════════════════════════════════════════════════════════════

# ── Required ──
OPENAI_API_KEY=your_openai_api_key

# ── Security ──
JWT_SECRET=change-this-to-a-random-64-char-string
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ── Email Sending (Phase 4) ──
# Option 1: SendGrid (recommended)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=complaints@grippy.ai

# Option 2: SMTP (Gmail, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=your_email@gmail.com

# ── Browser Pool (Phase 2) ──
BROWSER_POOL_SIZE=3
BROWSER_MAX_USES=50

# ── Session Store (Phase 2) ──
# Leave empty to use in-memory store (single-worker only)
REDIS_URL=redis://localhost:6379/0

# ── CAPTCHA Solving (optional) ──
TWOCAPTCHA_API_KEY=your_2captcha_key
ANTICAPTCHA_API_KEY=your_anticaptcha_key

# ── Search Providers (Phase 5) ──
# Set any of these for autonomous form discovery.
# Falls back to DuckDuckGo HTML scraping if none are set.
SERPAPI_KEY=your_serpapi_key
TAVILY_API_KEY=your_tavily_key
BRAVE_API_KEY=your_brave_key

# ── Follow-up Scheduler (Phase 7) ──
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_SECONDS=86400
FOLLOWUP_DAYS=7
MAX_AUTO_ESCALATIONS=3
GRIPPY_JWT_SECRET=dev-local-secret
